    ds=platKeys.map(plat=>({label:plat+' ('+yr+')',data:d[plat],borderColor:PC[plat],borderDash:[],tension:.4,pointRadius:4,pointBackgroundColor:PC[plat],fill:false,borderWidth:2.5}));
  } else {
    // Fiscal Year: multi-year comparison, one line per platform per year
    const yrs=activeYrs.length?activeYrs:['2026'];
    labels=MO;ds=[];
    yrs.forEach(yr=>{
      const d=NFOL[prof][yr];
      const allPlats=['Facebook','Instagram','X','TikTok'];
      const activePlats=on('[data-nplat]').length?on('[data-nplat]'):allPlats;
      const platKeys=allPlats.filter(p=>activePlats.includes(p));
      platKeys.forEach(plat=>{
        ds.push({label:plat+' ('+yr+')',data:d[plat].slice(0,4),borderColor:PC[plat],borderDash:YR_DASH[yr]||[],tension:.4,pointRadius:4,pointBackgroundColor:PC[plat],fill:false,borderWidth:2});
      });
    });
  }
  const dummy_yr=activeYrs[0]||'2026'; // for compat below
  if(charts.nfol)charts.nfol.destroy();
  charts.nfol=new Chart(document.getElementById('newFolChart'),{type:'line',data:{labels,datasets:ds},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>c.dataset.label+': '+fmtK(c.parsed.y)}}},scales:{x:{ticks:{font:{size:11},color:GR},grid:{display:false},autoSkip:false},y:{ticks:{font:{size:10},color:GR,callback:v=>fmtK(v)},grid:{color:'rgba(0,0,0,.06)'},border:{dash:[4,4]}}}}});
  document.getElementById('nfolLeg').innerHTML=ds.map(ds2=>`<div class="legend-item"><div class="legend-dot" style="background:${ds2.borderColor}"></div>${ds2.label}</div>`).join('');
}
pg('[data-prof]',false,rebuildNFol);
pg('[data-n4tp]',false,rebuildNFol);
// Platform filter: multi-select, at least one always on
document.querySelectorAll('[data-nplat]').forEach(btn=>{
  btn.addEventListener('click',()=>{
    btn.classList.toggle('on');
    if(on('[data-nplat]').length===0) btn.classList.add('on');
    rebuildNFol();
  });
});
document.querySelectorAll('[data-nyr]').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const tp=on('[data-n4tp]')[0]||'month';
    if(tp==='fy'){
      // Full Year: single-select
      document.querySelectorAll('[data-nyr]').forEach(b=>b.classList.remove('on'));
      btn.classList.add('on');
    } else {
      // Fiscal Year: multi-select
      btn.classList.toggle('on');
      if(on('[data-nyr]').length===0) btn.classList.add('on');
    }
    rebuildNFol();
  });
});
pg('[data-a2tp]',false,buildApp);
document.querySelectorAll('[data-ayr]').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const tp=on('[data-a2tp]')[0]||'month';
    if(tp==='fy'){
      // Full Year: single-select
      document.querySelectorAll('[data-ayr]').forEach(b=>b.classList.remove('on'));
      btn.classList.add('on');
    } else {
      // Fiscal Year: multi-select
      btn.classList.toggle('on');
      if(on('[data-ayr]').length===0) btn.classList.add('on');
    }
    buildApp();
  });
});
buildApp();
rebuildNFol();
</script>
</body>
