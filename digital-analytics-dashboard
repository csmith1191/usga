function rebuildMain(){
  const m=on('[data-m]')[0]||'pv', tp=on('[data-view]')[0]||'month', yrs=on('[data-fy]'), d=TOP[m];
  // Year group: single-select in Full Year mode, multi-select in Fiscal Year mode
  document.getElementById('mainYearGroup').style.display='flex';
  const activeYrs=on('[data-fy]');
  let labels,datasets,subtitle;
  if(tp==='fy'){
    // Full Year: show all 12 months for the selected year (filter out nulls)
    const yr=activeYrs[0]||'2025';
