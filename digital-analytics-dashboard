<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<style>
:root{
  --navy:#00365F;--blue:#0088CE;--red:#DA1A31;--green:#A2B528;--gray:#63666A;--bronze:#B79157;
  --border:#D8DEE3;--bg:#F5F7F9;--white:#FFFFFF;
  --text-primary:#1A2733;--text-secondary:#4A5A64;--text-muted:#7A8B94;
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:13px;color:var(--text-primary);background:var(--bg);}

/* ═══ LAYOUT ═══ */
.dashboard{max-width:960px;margin:0 auto;padding:20px 16px 40px;}

/* ═══ HEADER ═══ */
.hdr{
  background:var(--navy);border-radius:10px;
  padding:14px 20px;margin-bottom:18px;
  display:flex;align-items:center;justify-content:space-between;
}
.hdr-title{font-size:17px;font-weight:700;color:#fff;letter-spacing:.01em;}
.hdr-sub{font-size:11px;color:#9AB8CC;margin-top:3px;}
.hdr-right{display:flex;align-items:center;gap:12px;}
.hdr-badge{
  background:var(--red);color:#fff;
  font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;
  padding:4px 13px;border-radius:999px;
}
.hdr-logo{height:42px;width:42px;border-radius:5px;object-fit:contain;background:#fff;padding:3px;display:block;}

/* ═══ TOPLINE LABEL ═══ */
.section-label{
  font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;
  color:var(--text-muted);border-left:3px solid var(--red);
  padding-left:8px;margin:18px 0 10px;
}

/* ═══ METRIC CARDS ═══ */
.metric-grid{
  display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:18px;
}
.metric-card{
  background:var(--white);border:1px solid var(--border);border-radius:8px;
  border-top:3px solid var(--navy);padding:12px 14px;
}
.metric-card .label{font-size:10px;color:var(--text-muted);font-weight:500;margin-bottom:4px;}
.metric-card .value{font-size:22px;font-weight:700;color:var(--navy);line-height:1;}
.metric-card .delta{font-size:10px;font-weight:600;margin-top:5px;}
.delta-up{color:#3A6614;}
.delta-dn{color:var(--red);}

/* ═══ SECTION DIVIDER ═══ */
.sec-divider{
  display:flex;align-items:center;gap:10px;
  margin:26px 0 14px;
}
.sec-divider .line{flex:1;height:1px;background:var(--border);}
.sec-divider .num{
  width:22px;height:22px;border-radius:50%;
  background:var(--red);color:#fff;
  font-size:10px;font-weight:700;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.sec-divider .label-text{
  font-size:10px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;
  color:var(--navy);white-space:nowrap;
}

/* ═══ CHART CARD ═══ */
.card{
  background:var(--white);border:1px solid var(--border);border-radius:8px;
  padding:16px 18px;margin-bottom:14px;
}
.card-title{font-size:13px;font-weight:700;color:var(--navy);margin-bottom:2px;}
.card-sub{font-size:10px;color:var(--text-muted);margin-bottom:12px;}

/* ═══ FILTER BAR ═══ */
.filter-bar{
  display:flex;flex-wrap:wrap;align-items:stretch;
  border:1px solid #BBC5CC;border-radius:6px;
  overflow:hidden;background:#2C3A47;margin-bottom:14px;
}
.filter-group{
  display:flex;align-items:center;gap:4px;
  padding:6px 10px;border-right:1px solid #3E5060;
  flex-shrink:0;
}
.filter-group:last-child{border-right:none;}
.filter-group .flabel{
  font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;
  color:#7A97AA;margin-right:4px;white-space:nowrap;flex-shrink:0;
}
.fpill{
  font-size:10px;font-weight:500;padding:3px 10px;
  border-radius:4px;border:1px solid transparent;
  background:transparent;color:#94AABB;
  cursor:pointer;white-space:nowrap;line-height:1.4;
  transition:all .12s ease;
}
.fpill:hover{background:#3A5060;color:#C8D8E4;}
.fpill.on{background:var(--navy);color:#fff;border-color:#004A7F;font-weight:600;}

/* ═══ LEGEND ═══ */
.legend{display:flex;flex-wrap:wrap;gap:12px;margin-bottom:10px;}
.legend-item{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--text-secondary);font-weight:500;}
.legend-dot{width:10px;height:10px;border-radius:2px;flex-shrink:0;}

/* ═══ FOLLOWERS GRID ═══ */
.fol-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;}
.fol-card{
  background:var(--white);border:1px solid var(--border);border-radius:8px;
  border-top:3px solid var(--blue);padding:14px 16px;
}
.fol-platform{font-size:10px;font-weight:700;color:var(--navy);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px;}
.fol-table{width:100%;border-collapse:collapse;}
.fol-table thead th{
  font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;
  color:var(--text-muted);padding:0 0 6px;border-bottom:1.5px solid var(--border);
  text-align:right;
}
.fol-table thead th:first-child{text-align:left;}
.fol-table tbody td{
  font-size:11px;padding:5px 0;border-bottom:.5px solid #EEF1F3;
  text-align:right;color:var(--text-secondary);
}
.fol-table tbody td:first-child{text-align:left;color:var(--text-primary);}
.fol-table tbody tr:last-child td{border-bottom:none;}
.fol-table tfoot td{
  font-size:11px;font-weight:700;padding:7px 0 0;
  border-top:1.5px solid var(--navy);color:var(--navy);
  text-align:right;
}
.fol-table tfoot td:first-child{text-align:left;}
.fol-count{font-weight:700;color:var(--navy);}
.delta-up-sm{color:#3A6614;font-size:10px;font-weight:600;}
.delta-dn-sm{color:var(--red);font-size:10px;font-weight:600;}

/* ═══ APP VISUAL ═══ */
.app-scroll{overflow-x:auto;padding-bottom:6px;}
.app-row{display:flex;gap:10px;min-width:max-content;align-items:flex-end;padding:4px 0;}
.app-year-block{display:flex;align-items:flex-end;gap:8px;}
.app-year-label{
  writing-mode:vertical-lr;transform:rotate(180deg);
  font-size:9px;font-weight:700;color:var(--navy);letter-spacing:.06em;
  margin-right:4px;align-self:center;
}
.app-col{display:flex;flex-direction:column;align-items:center;gap:4px;}
.app-month-lbl{font-size:9px;color:var(--text-muted);font-weight:600;text-align:center;}
.app-bar-stack{display:flex;flex-direction:column;gap:2px;width:44px;height:100px;justify-content:flex-end;}
.app-seg{
  display:flex;flex-direction:column;justify-content:center;
  border-radius:3px;min-height:6px;padding:1px 5px;
  border-left:3px solid transparent;
}
.app-seg-pct{font-size:8px;font-weight:700;line-height:1.2;}
.app-seg-lbl{font-size:7px;opacity:.75;line-height:1;}
.app-total-lbl{font-size:9px;font-weight:700;color:var(--navy);text-align:center;}
.app-year-sep{width:1px;background:var(--border);height:100px;margin:0 4px;align-self:flex-end;}
</style>
</head>
