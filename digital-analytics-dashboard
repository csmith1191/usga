let charts={};

function pg(sel,multi,cb){
  document.querySelectorAll(sel).forEach(b=>{
    b.addEventListener('click',()=>{
      if(multi)b.classList.toggle('on');
      else{document.querySelectorAll(sel).forEach(x=>x.classList.remove('on'));b.classList.add('on');}
      cb();
    });
  });
}
function on(sel){return[...document.querySelectorAll(sel)].filter(b=>b.classList.contains('on')).map(b=>Object.values(b.dataset)[0]);}

